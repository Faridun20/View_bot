# --- Скопируйте этот файл в .env и заполните ---

# Токен бота, полученный у @BotFather (обязательно)
TG_BOT_TOKEN=

# Ваш Telegram user_id через запятую (необязательно, для будущих /admin-команд)
# Узнать ID можно у бота @userinfobot
ADMIN_IDS=

# Куда складывать SQLite и cookies. На Railway = /data (volume).
# Локально оставьте дефолт.
DATA_DIR=data

# Период проверки сайта в минутах (по умолчанию 60)
MONITOR_INTERVAL_MINUTES=60

# Сколько лотов одному пользователю максимум за один прогон (защита от спама)
MAX_NOTIFICATIONS_PER_RUN=20

# Сколько последних лотов «зачесть как уже виденные» при ПЕРВОМ запуске,
# чтобы не утопить подписчиков в сотнях старых объявлений.
SEED_RECENT_LOTS=200

# Включать ли в мониторинг навесное оборудование (어태치먼트) и запчасти
# (굴삭기부속). По умолчанию false — приходят только сами экскаваторы.
# Поставьте true, если хотите видеть запчасти/ковши/гидромолоты.
INCLUDE_PARTS=false

# DEBUG / INFO / WARNING / ERROR
LOG_LEVEL=INFO
